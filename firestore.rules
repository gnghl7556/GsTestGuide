rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isProjectLocked(projectId) {
      let project = get(/databases/$(database)/documents/projects/$(projectId));
      return project.exists()
        && (project.data.status == '완료' || project.data.executionState.finalizedAt != null);
    }

    match /projects/{projectId}/defects/{defectId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && !isProjectLocked(projectId);
    }

    // 콘텐츠 버전 관리: 루트 문서 (읽기/쓰기 가능)
    match /contentVersions/{reqId} {
      allow read, write: if isSignedIn();
    }

    // 콘텐츠 버전 히스토리: 생성만 허용, 수정/삭제 불가 (불변 이력)
    match /contentVersions/{reqId}/versions/{v} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
